/* ============================================================
   DIAGNOSTIC 1:
   Find OV meter-reading style parameter values for complained
   samples through Sample -> Runset -> Task -> Task Parameters.

   Goal:
   - Confirm whether OneLab has the meter values in COR_PARAMETER_VALUE
   - Show whether the missing samples have OV Meter Reading rows
   - Show ITEM_INDEX / GROUP_INDEX so we can map table-style rows
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id          AS sample_pk,
        s.name        AS sample_name,
        s.sample_id   AS sample_id,
        s.life_cycle_state AS sample_status
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
),
runset_scope AS (
    SELECT
        ss.*,
        rs.id        AS runset_pk,
        rs.name      AS runset_name,
        rs.runset_id AS runset_id,
        rs.life_cycle_state AS runset_status
    FROM sample_scope ss
    JOIN req_runset_sample rss
        ON rss.sample_id = ss.sample_pk
    JOIN req_runset rs
        ON rs.id = rss.runset_id
),
task_scope AS (
    SELECT DISTINCT
        rs.*,
        t.id        AS task_pk,
        t.task_id   AS task_id,
        t.task_name AS task_name,
        t.work_item_template,
        t.executed_activity_name,
        t.life_cycle_state AS task_status,
        t.date_created AS task_created,
        t.last_updated AS task_updated
    FROM runset_scope rs
    JOIN req_task t
        ON t.runset_id = rs.runset_pk
        OR t.alt_runset_id = rs.runset_pk
),
param_rows AS (
    SELECT
        ts.target_sample,
        ts.sample_name,
        ts.sample_id,
        ts.runset_name,
        ts.runset_id,
        ts.task_id,
        ts.task_name,
        ts.work_item_template,
        ts.executed_activity_name,
        ts.task_status,

        cp.id AS parameter_pk,
        cp.name AS parameter_name,
        cp.display_name AS parameter_display_name,
        cp.value_type AS parameter_value_type,

        cpv.item_index,
        cpv.group_index,
        cpv.value_key,
        cpv.value_type AS actual_value_type,
        cpv.unit_urn,
        cpv.unit,

        cpv.value_numeric,
        cpv.value_numeric_text,
        cpv.value_integer,
        cpv.value_string,
        cpv.value_text,
        CASE
            WHEN cpv.value_long_text IS NOT NULL
            THEN DBMS_LOB.SUBSTR(cpv.value_long_text, 1000, 1)
        END AS value_long_text_snip,

        cpv.last_updated AS value_last_updated
    FROM task_scope ts
    JOIN req_task_parameter rtp
        ON rtp.task_id = ts.task_pk
    JOIN cor_parameter cp
        ON cp.id = rtp.parameter_id
    LEFT JOIN cor_parameter_value cpv
        ON cpv.parent_identity = cp.id
       AND NVL(cpv.deleted, 'N') <> 'Y'
    WHERE
        LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%ov%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%meter%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%data id%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%instrument sample%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%sampling point%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%sampling time%'
)
SELECT
    target_sample,
    sample_name,
    sample_id,
    runset_name,
    runset_id,
    task_id,
    task_name,
    work_item_template,
    executed_activity_name,
    task_status,
    parameter_name,
    parameter_display_name,
    item_index,
    group_index,
    value_key,
    value_numeric,
    value_numeric_text,
    value_integer,
    value_string,
    value_text,
    value_long_text_snip,
    unit_urn,
    value_last_updated
FROM param_rows
ORDER BY
    target_sample,
    runset_name,
    task_id,
    item_index NULLS LAST,
    group_index NULLS LAST,
    parameter_display_name,
    parameter_name;
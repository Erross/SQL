/* ============================================================
   DIAGNOSTIC 1:
   Find OV meter-reading style parameter values for complained
   samples through Sample -> Runset -> Task -> Task Parameters.

   Goal:
   - Confirm whether OneLab has the meter values in COR_PARAMETER_VALUE
   - Show whether the missing samples have OV Meter Reading rows
   - Show ITEM_INDEX / GROUP_INDEX so we can map table-style rows
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id          AS sample_pk,
        s.name        AS sample_name,
        s.sample_id   AS sample_id,
        s.life_cycle_state AS sample_status
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
),
runset_scope AS (
    SELECT
        ss.*,
        rs.id        AS runset_pk,
        rs.name      AS runset_name,
        rs.runset_id AS runset_id,
        rs.life_cycle_state AS runset_status
    FROM sample_scope ss
    JOIN req_runset_sample rss
        ON rss.sample_id = ss.sample_pk
    JOIN req_runset rs
        ON rs.id = rss.runset_id
),
task_scope AS (
    SELECT DISTINCT
        rs.*,
        t.id        AS task_pk,
        t.task_id   AS task_id,
        t.task_name AS task_name,
        t.work_item_template,
        t.executed_activity_name,
        t.life_cycle_state AS task_status,
        t.date_created AS task_created,
        t.last_updated AS task_updated
    FROM runset_scope rs
    JOIN req_task t
        ON t.runset_id = rs.runset_pk
        OR t.alt_runset_id = rs.runset_pk
),
param_rows AS (
    SELECT
        ts.target_sample,
        ts.sample_name,
        ts.sample_id,
        ts.runset_name,
        ts.runset_id,
        ts.task_id,
        ts.task_name,
        ts.work_item_template,
        ts.executed_activity_name,
        ts.task_status,

        cp.id AS parameter_pk,
        cp.name AS parameter_name,
        cp.display_name AS parameter_display_name,
        cp.value_type AS parameter_value_type,

        cpv.item_index,
        cpv.group_index,
        cpv.value_key,
        cpv.value_type AS actual_value_type,
        cpv.unit_urn,
        cpv.unit,

        cpv.value_numeric,
        cpv.value_numeric_text,
        cpv.value_integer,
        cpv.value_string,
        cpv.value_text,
        CASE
            WHEN cpv.value_long_text IS NOT NULL
            THEN DBMS_LOB.SUBSTR(cpv.value_long_text, 1000, 1)
        END AS value_long_text_snip,

        cpv.last_updated AS value_last_updated
    FROM task_scope ts
    JOIN req_task_parameter rtp
        ON rtp.task_id = ts.task_pk
    JOIN cor_parameter cp
        ON cp.id = rtp.parameter_id
    LEFT JOIN cor_parameter_value cpv
        ON cpv.parent_identity = cp.id
       AND NVL(cpv.deleted, 'N') <> 'Y'
    WHERE
        LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%ov%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%meter%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%data id%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%instrument sample%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%sampling point%'
        OR LOWER(NVL(cp.name, '') || ' ' || NVL(cp.display_name, '')) LIKE '%sampling time%'
)
SELECT
    target_sample,
    sample_name,
    sample_id,
    runset_name,
    runset_id,
    task_id,
    task_name,
    work_item_template,
    executed_activity_name,
    task_status,
    parameter_name,
    parameter_display_name,
    item_index,
    group_index,
    value_key,
    value_numeric,
    value_numeric_text,
    value_integer,
    value_string,
    value_text,
    value_long_text_snip,
    unit_urn,
    value_last_updated
FROM param_rows
ORDER BY
    target_sample,
    runset_name,
    task_id,
    item_index NULLS LAST,
    group_index NULLS LAST,
    parameter_display_name,
    parameter_name;

    /* ============================================================
   DIAGNOSTIC 2:
   Look directly in RES_MEASUREMENT / RES_MEASUREMENTSAMPLE
   for meter readings mapped to the complaint samples.

   This checks whether the missing OV Meter Reading [%] values
   are stored as equipment measurement raw data rather than
   task parameter values.
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id,
        s.life_cycle_state AS sample_status
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
)
SELECT
    ss.target_sample,
    ss.sample_name,
    ss.sample_id,
    ss.sample_status,

    rms.id AS measurementsample_pk,
    rms.sample_id AS rms_sample_id_text,
    rms.mapped_sample_id,
    rms.row_index,
    rms.context_id,

    rm.id AS measurement_pk,
    rm.record_name,
    rm.measurement_type,
    rm.context,
    rm.equipment_work_item_id,
    rm.command_id,
    rm.equipment_id,
    rm.record_date,
    rm.date_created,
    rm.last_updated,

    rm.raw_data,
    CASE
        WHEN rm.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(rm.raw_data_long_text, 3000, 1)
    END AS raw_data_long_text_snip

FROM sample_scope ss
JOIN res_measurementsample rms
    ON rms.mapped_sample_id = ss.sample_pk
    OR rms.sample_id = ss.sample_name
    OR rms.sample_id = ss.sample_id
JOIN res_measurement rm
    ON rm.id = rms.measurement_id
WHERE
       LOWER(NVL(rm.record_name, '')) LIKE '%ov%'
    OR LOWER(NVL(rm.record_name, '')) LIKE '%meter%'
    OR LOWER(NVL(rm.measurement_type, '')) LIKE '%ov%'
    OR LOWER(NVL(rm.measurement_type, '')) LIKE '%meter%'
    OR LOWER(NVL(rm.raw_data, '')) LIKE '%ov%'
    OR LOWER(NVL(rm.raw_data, '')) LIKE '%meter%'
    OR DBMS_LOB.INSTR(LOWER(rm.raw_data_long_text), 'ov') > 0
    OR DBMS_LOB.INSTR(LOWER(rm.raw_data_long_text), 'meter') > 0
ORDER BY
    ss.target_sample,
    rm.record_date,
    rms.row_index;
    
    --bigger q

    /* ============================================================
   DIAGNOSTIC 3:
   Show all RES_MEASUREMENT rows mapped to complaint samples,
   regardless of whether the text says OV/meter.

   Use this if Diagnostic 2 misses because the raw data uses
   numeric column names or JSON field names we did not anticipate.
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id,
        s.life_cycle_state AS sample_status
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
)
SELECT
    ss.target_sample,
    ss.sample_name,
    ss.sample_id,
    ss.sample_status,

    rms.id AS measurementsample_pk,
    rms.sample_id AS rms_sample_id_text,
    rms.mapped_sample_id,
    rms.row_index,
    rms.context_id,

    rm.id AS measurement_pk,
    rm.record_name,
    rm.measurement_type,
    rm.context,
    rm.equipment_work_item_id,
    rm.command_id,
    rm.equipment_id,
    rm.record_date,
    rm.date_created,
    rm.last_updated,

    SUBSTR(rm.raw_data, 1, 1000) AS raw_data_snip,
    CASE
        WHEN rm.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(rm.raw_data_long_text, 3000, 1)
    END AS raw_data_long_text_snip

FROM sample_scope ss
JOIN res_measurementsample rms
    ON rms.mapped_sample_id = ss.sample_pk
    OR rms.sample_id = ss.sample_name
    OR rms.sample_id = ss.sample_id
JOIN res_measurement rm
    ON rm.id = rms.measurement_id
ORDER BY
    ss.target_sample,
    rm.record_date,
    rms.row_index,
    rm.record_name;

    /* ============================================================
   DIAGNOSTIC A:
   For the missing OV samples, show the measurement packet,
   work item, equipment type, data packet, and field definitions.

   This should tell us whether the packet definition contains:
   - Instrument Sample ID
   - Data Id
   - Meter Number
   - OV Meter Reading [%]
   - Sampling Point Time
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
),
measurement_scope AS (
    SELECT
        ss.target_sample,
        ss.sample_name,
        ss.sample_id,
        rms.id AS measurementsample_pk,
        rms.sample_id AS rms_sample_id_text,
        rms.mapped_sample_id,
        rms.row_index,
        rms.context_id,
        rm.id AS measurement_pk,
        rm.record_name,
        rm.measurement_type,
        rm.record_date,
        rm.date_created,
        rm.last_updated,
        rm.equipment_work_item_id,
        rm.equipment_id,
        rm.command_id,
        rm.raw_data,
        rm.raw_data_long_text,
        rm.info
    FROM sample_scope ss
    JOIN res_measurementsample rms
        ON rms.mapped_sample_id = ss.sample_pk
        OR rms.sample_id = ss.sample_name
        OR rms.sample_id = ss.sample_id
    JOIN res_measurement rm
        ON rm.id = rms.measurement_id
    WHERE rm.measurement_type = 'Data Packet'
)
SELECT
    ms.target_sample,
    ms.sample_name,
    ms.sample_id,
    ms.rms_sample_id_text,
    ms.row_index,
    ms.record_name,
    ms.measurement_type,
    ms.record_date,
    ms.date_created,
    ms.last_updated,

    ms.measurement_pk,
    ms.measurementsample_pk,
    ms.context_id,
    ms.equipment_work_item_id,
    ms.equipment_id,
    ms.command_id,

    e.nickname AS equipment_nickname,
    e.serial_number AS equipment_serial_number,
    et.name AS equipment_type_name,

    dp.name AS data_packet_name,
    SUBSTR(dp.data, 1, 1000) AS data_packet_data_snip,

    df.display_order AS field_display_order,
    df.name AS data_field_name,
    df.field_type AS data_field_type,
    df.series AS data_field_series,
    df.is_sample_id,
    df.is_group_by,
    df.required,
    df.data AS data_field_data,
    u.name AS unit_name,

    SUBSTR(ms.info, 1, 2000) AS measurement_info_snip,
    SUBSTR(ms.raw_data, 1, 1000) AS raw_data_snip,
    CASE
        WHEN ms.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(ms.raw_data_long_text, 2000, 1)
    END AS raw_data_long_text_snip,

    ewi.state AS work_item_state,
    ewi.work_item_identifier,
    SUBSTR(ewi.additional_context, 1, 2000) AS work_item_additional_context,
    SUBSTR(ewi.file_references, 1, 2000) AS work_item_file_references,
    ewi.last_parse_result

FROM measurement_scope ms
LEFT JOIN res_equipment e
    ON e.id = ms.equipment_id
LEFT JOIN res_equipment_type et
    ON et.id = e.equipment_type_id
LEFT JOIN res_data_packet dp
    ON dp.id = et.data_packet_id
LEFT JOIN res_data_field df
    ON df.data_packet_id = dp.id
LEFT JOIN cor_unit u
    ON u.id = df.unit_id
LEFT JOIN res_equipment_work_item ewi
    ON ewi.id = ms.equipment_work_item_id
ORDER BY
    ms.target_sample,
    ms.record_date,
    ms.row_index,
    df.display_order NULLS LAST,
    df.name;
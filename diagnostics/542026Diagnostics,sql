    rms.id AS measurementsample_pk,
    rms.sample_id AS rms_sample_id_text,
    rms.mapped_sample_id,
    rms.row_index,
    rms.context_id,

    rm.id AS measurement_pk,
    rm.record_name,
    rm.measurement_type,
    rm.context,
    rm.equipment_work_item_id,
    rm.command_id,
    rm.equipment_id,
    rm.record_date,
    rm.date_created,
    rm.last_updated,

    SUBSTR(rm.raw_data, 1, 1000) AS raw_data_snip,
    CASE
        WHEN rm.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(rm.raw_data_long_text, 3000, 1)
    END AS raw_data_long_text_snip

FROM sample_scope ss
JOIN res_measurementsample rms
    ON rms.mapped_sample_id = ss.sample_pk
    OR rms.sample_id = ss.sample_name
    OR rms.sample_id = ss.sample_id
JOIN res_measurement rm
    ON rm.id = rms.measurement_id
ORDER BY
    ss.target_sample,
    rm.record_date,
    rms.row_index,
    rm.record_name;

    /* ============================================================
   DIAGNOSTIC A:
   For the missing OV samples, show the measurement packet,
   work item, equipment type, data packet, and field definitions.

   This should tell us whether the packet definition contains:
   - Instrument Sample ID
   - Data Id
   - Meter Number
   - OV Meter Reading [%]
   - Sampling Point Time
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
),
measurement_scope AS (
    SELECT
        ss.target_sample,
        ss.sample_name,
        ss.sample_id,
        rms.id AS measurementsample_pk,
        rms.sample_id AS rms_sample_id_text,
        rms.mapped_sample_id,
        rms.row_index,
        rms.context_id,
        rm.id AS measurement_pk,
        rm.record_name,
        rm.measurement_type,
        rm.record_date,
        rm.date_created,
        rm.last_updated,
        rm.equipment_work_item_id,
        rm.equipment_id,
        rm.command_id,
        rm.raw_data,
        rm.raw_data_long_text,
        rm.info
    FROM sample_scope ss
    JOIN res_measurementsample rms
        ON rms.mapped_sample_id = ss.sample_pk
        OR rms.sample_id = ss.sample_name
        OR rms.sample_id = ss.sample_id
    JOIN res_measurement rm
        ON rm.id = rms.measurement_id
    WHERE rm.measurement_type = 'Data Packet'
)
SELECT
    ms.target_sample,
    ms.sample_name,
    ms.sample_id,
    ms.rms_sample_id_text,
    ms.row_index,
    ms.record_name,
    ms.measurement_type,
    ms.record_date,
    ms.date_created,
    ms.last_updated,

    ms.measurement_pk,
    ms.measurementsample_pk,
    ms.context_id,
    ms.equipment_work_item_id,
    ms.equipment_id,
    ms.command_id,

    e.nickname AS equipment_nickname,
    e.serial_number AS equipment_serial_number,
    et.name AS equipment_type_name,

    dp.name AS data_packet_name,
    SUBSTR(dp.data, 1, 1000) AS data_packet_data_snip,

    df.display_order AS field_display_order,
    df.name AS data_field_name,
    df.field_type AS data_field_type,
    df.series AS data_field_series,
    df.is_sample_id,
    df.is_group_by,
    df.required,
    df.data AS data_field_data,
    u.name AS unit_name,

    SUBSTR(ms.info, 1, 2000) AS measurement_info_snip,
    SUBSTR(ms.raw_data, 1, 1000) AS raw_data_snip,
    CASE
        WHEN ms.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(ms.raw_data_long_text, 2000, 1)
    END AS raw_data_long_text_snip,

    ewi.state AS work_item_state,
    ewi.work_item_identifier,
    SUBSTR(ewi.additional_context, 1, 2000) AS work_item_additional_context,
    SUBSTR(ewi.file_references, 1, 2000) AS work_item_file_references,
    ewi.last_parse_result

FROM measurement_scope ms
LEFT JOIN res_equipment e
    ON e.id = ms.equipment_id
LEFT JOIN res_equipment_type et
    ON et.id = e.equipment_type_id
LEFT JOIN res_data_packet dp
    ON dp.id = et.data_packet_id
LEFT JOIN res_data_field df
    ON df.data_packet_id = dp.id
LEFT JOIN cor_unit u
    ON u.id = df.unit_id
LEFT JOIN res_equipment_work_item ewi
    ON ewi.id = ms.equipment_work_item_id
ORDER BY
    ms.target_sample,
    ms.record_date,
    ms.row_index,
    df.display_order NULLS LAST,
    df.name;

    /* ============================================================
   DIAGNOSTIC B:
   Compare a known-good exported ov_meter_reading sample against
   known-missing complaint samples.

   Known-good examples from the current export:
   - S006375 has ov_meter_reading
   - S004384 has ov_meter_reading

   Known-missing examples:
   - S007425
   - S004742
   ============================================================ */

WITH target_samples AS (
    SELECT 'GOOD_EXPORT_HAS_OV' AS bucket, 'S006375' AS sample_name FROM dual UNION ALL
    SELECT 'GOOD_EXPORT_HAS_OV', 'S004384' FROM dual UNION ALL
    SELECT 'MISSING_OV', 'S007425' FROM dual UNION ALL
    SELECT 'MISSING_OV', 'S004742' FROM dual
),
sample_scope AS (
    SELECT
        ts.bucket,
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
)
SELECT
    ss.bucket,
    ss.target_sample,
    ss.sample_name,
    ss.sample_id,

    rms.id AS measurementsample_pk,
    rms.sample_id AS rms_sample_id_text,
    rms.mapped_sample_id,
    rms.row_index,
    rms.context_id,

    rm.id AS measurement_pk,
    rm.record_name,
    rm.measurement_type,
    rm.record_date,
    rm.date_created,
    rm.last_updated,
    rm.equipment_work_item_id,
    rm.equipment_id,
    rm.command_id,

    SUBSTR(rm.info, 1, 3000) AS measurement_info_snip,
    SUBSTR(rm.raw_data, 1, 1000) AS raw_data_snip,
    CASE
        WHEN rm.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(rm.raw_data_long_text, 3000, 1)
    END AS raw_data_long_text_snip,

    e.nickname AS equipment_nickname,
    et.name AS equipment_type_name,
    dp.name AS data_packet_name,

    ewi.state AS work_item_state,
    ewi.work_item_identifier,
    SUBSTR(ewi.additional_context, 1, 3000) AS work_item_additional_context,
    SUBSTR(ewi.file_references, 1, 3000) AS work_item_file_references,
    ewi.last_parse_result

FROM sample_scope ss
LEFT JOIN res_measurementsample rms
    ON rms.mapped_sample_id = ss.sample_pk
    OR rms.sample_id = ss.sample_name
    OR rms.sample_id = ss.sample_id
LEFT JOIN res_measurement rm
    ON rm.id = rms.measurement_id
LEFT JOIN res_equipment e
    ON e.id = rm.equipment_id
LEFT JOIN res_equipment_type et
    ON et.id = e.equipment_type_id
LEFT JOIN res_data_packet dp
    ON dp.id = et.data_packet_id
LEFT JOIN res_equipment_work_item ewi
    ON ewi.id = rm.equipment_work_item_id
WHERE
    rm.measurement_type = 'Data Packet'
    OR rm.measurement_type IS NULL
ORDER BY
    ss.bucket,
    ss.target_sample,
    rm.record_date,
    rms.row_index;

    --metachecker

    /* ============================================================
   DIAGNOSTIC C:
   Look for file metadata rows matching the parser result files
   referenced by RES_EQUIPMENT_WORK_ITEM.LAST_PARSE_RESULT.

   Goal:
   Determine whether the CSV / parsed_xy_data files are available
   through OneLab file metadata tables, or only as PLP runtime URLs.
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S006375' FROM dual UNION ALL
    SELECT 'S004384' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
),
packet_scope AS (
    SELECT DISTINCT
        ss.target_sample,
        ss.sample_name,
        ss.sample_id,
        rms.id AS measurementsample_pk,
        rms.sample_id AS rms_sample_id_text,
        rms.mapped_sample_id,
        rms.row_index,
        rm.id AS measurement_pk,
        rm.record_name,
        rm.measurement_type,
        rm.equipment_work_item_id,
        ewi.work_item_identifier,
        ewi.last_parse_result
    FROM sample_scope ss
    JOIN res_measurementsample rms
        ON rms.mapped_sample_id = ss.sample_pk
        OR rms.sample_id = ss.sample_name
        OR rms.sample_id = ss.sample_id
    JOIN res_measurement rm
        ON rm.id = rms.measurement_id
    LEFT JOIN res_equipment_work_item ewi
        ON ewi.id = rm.equipment_work_item_id
    WHERE rm.measurement_type = 'Data Packet'
)
SELECT
    ps.target_sample,
    ps.sample_name,
    ps.sample_id,
    ps.rms_sample_id_text,
    ps.row_index,
    ps.measurement_pk,
    ps.record_name,
    ps.equipment_work_item_id,
    ps.work_item_identifier,

    fm.id AS file_metadata_id,
    fm.name AS file_name,
    fm.mime_type,
    fm.storage_type,
    fm.file_size,
    fm.date_created AS file_date_created,
    fm.last_updated AS file_last_updated,

    s3.bucket_name,
    s3.uri AS s3_uri,
    s3.region,
    s3.endpoint,

    ref.url AS ref_url,

    SUBSTR(ps.last_parse_result, 1, 3000) AS last_parse_result_snip

FROM packet_scope ps
LEFT JOIN file_metadata fm
    ON LOWER(fm.name) = LOWER(ps.record_name)
    OR LOWER(ps.last_parse_result) LIKE '%' || LOWER(fm.name) || '%'
LEFT JOIN hub_s3_file_metadata s3
    ON s3.file_id = fm.id
LEFT JOIN hub_ref_url_file_metadata ref
    ON ref.file_id = fm.id
ORDER BY
    ps.target_sample,
    ps.record_name,
    fm.name;

    --metachecker2

    /* ============================================================
   DIAGNOSTIC D:
   Search COR_PARAMETER_VALUE for the known-good OV readings.

   We know these values appear in the export:
   S006375 = 14.1097
   S004384 = 19.0320

   If these show up in COR_PARAMETER_VALUE, then the current report
   is getting good rows from task/result parameters, while missing
   packet-only rows.
   ============================================================ */

SELECT
    cp.id AS parameter_pk,
    cp.name AS parameter_name,
    cp.display_name AS parameter_display_name,
    cp.value_type AS parameter_value_type,

    cpv.id AS parameter_value_pk,
    cpv.parent_identity,
    cpv.item_index,
    cpv.group_index,
    cpv.value_key,
    cpv.value_numeric,
    cpv.value_numeric_text,
    cpv.value_integer,
    cpv.value_string,
    cpv.value_text,
    CASE
        WHEN cpv.value_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(cpv.value_long_text, 1000, 1)
    END AS value_long_text_snip,
    cpv.unit,
    cpv.unit_urn,
    cpv.last_updated
FROM cor_parameter cp
JOIN cor_parameter_value cpv
    ON cpv.parent_identity = cp.id
WHERE
       ABS(cpv.value_numeric - 14.1097) < 0.00001
    OR ABS(cpv.value_numeric - 19.0320) < 0.00001
    OR cpv.value_numeric_text IN ('14.1097', '19.0320', '14.109700', '19.032000')
    OR cpv.value_string IN ('14.1097', '19.0320', '14.109700', '19.032000')
    OR cpv.value_text IN ('14.1097', '19.0320', '14.109700', '19.032000')
ORDER BY
    cp.display_name,
    cp.name,
    cpv.last_updated DESC;

    --file
    /* ============================================================
   DIAGNOSTIC E:
   Read the actual uploaded equipment CSV from FILE_CONTENT.

   This should expose the rows containing:
   Sample_Id, Sampling_Point_Time, OV_Meter_Reading,
   Meter_Number, Data_Id

   Key point:
   FILE_METADATA.STORAGE_TYPE = 'DATABASE'
   FILE_CONTENT.CONTENT is the actual file BLOB.
   ============================================================ */

WITH exact_files AS (
    SELECT DISTINCT
        fm.id,
        fm.name,
        fm.file_size,
        fm.date_created,
        fm.last_updated,
        fm.mime_type,
        fm.storage_type
    FROM file_metadata fm
    WHERE fm.name IN (
        '268_Exit AC Flavor Cyl. #3_04-16-2026-FARRENJC.csv',
        '234_Enter Burley Spray #4_03-24-2026-FARRENJC.csv',
        '268_Exit AC Flavor Cyl. #3_04-09-2026-BAUMGAB.csv',
        '268_Exit AC Flavor Cyl. #3_04-09-2026-GODWINWS.csv'
    )
)
SELECT
    RAWTOHEX(ef.id) AS file_metadata_id,
    ef.name AS file_name,
    ef.file_size,
    ef.date_created,
    ef.last_updated,
    ef.mime_type,
    ef.storage_type,
    DBMS_LOB.GETLENGTH(fc.content) AS blob_length,

    UTL_RAW.CAST_TO_VARCHAR2(
        DBMS_LOB.SUBSTR(fc.content, 2000, 1)
    ) AS file_text_snip

FROM exact_files ef
JOIN file_content fc
    ON fc.file_id = ef.id
ORDER BY
    ef.name,
    ef.date_created;
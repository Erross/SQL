    /* ============================================================
   DIAGNOSTIC 3:
   Show all RES_MEASUREMENT rows mapped to complaint samples,
   regardless of whether the text says OV/meter.

   Use this if Diagnostic 2 misses because the raw data uses
   numeric column names or JSON field names we did not anticipate.
   ============================================================ */

WITH target_samples AS (
    SELECT 'S007425' AS sample_name FROM dual UNION ALL
    SELECT 'S007428' FROM dual UNION ALL
    SELECT 'S007431' FROM dual UNION ALL
    SELECT 'S007434' FROM dual UNION ALL
    SELECT 'S007438' FROM dual UNION ALL
    SELECT 'S007441' FROM dual UNION ALL
    SELECT 'S007450' FROM dual UNION ALL
    SELECT 'S007453' FROM dual UNION ALL
    SELECT 'S005476' FROM dual UNION ALL
    SELECT 'S005492' FROM dual UNION ALL
    SELECT 'S004362' FROM dual UNION ALL
    SELECT 'S004742' FROM dual UNION ALL
    SELECT 'S004745' FROM dual UNION ALL
    SELECT 'S004748' FROM dual UNION ALL
    SELECT 'S004751' FROM dual UNION ALL
    SELECT 'S004754' FROM dual UNION ALL
    SELECT 'S004757' FROM dual UNION ALL
    SELECT 'S004760' FROM dual
),
sample_scope AS (
    SELECT
        ts.sample_name AS target_sample,
        s.id           AS sample_pk,
        s.name         AS sample_name,
        s.sample_id    AS sample_id,
        s.life_cycle_state AS sample_status
    FROM target_samples ts
    JOIN sam_sample s
        ON s.name = ts.sample_name
        OR s.sample_id = ts.sample_name
)
SELECT
    ss.target_sample,
    ss.sample_name,
    ss.sample_id,
    ss.sample_status,

    rms.id AS measurementsample_pk,
    rms.sample_id AS rms_sample_id_text,
    rms.mapped_sample_id,
    rms.row_index,
    rms.context_id,

    rm.id AS measurement_pk,
    rm.record_name,
    rm.measurement_type,
    rm.context,
    rm.equipment_work_item_id,
    rm.command_id,
    rm.equipment_id,
    rm.record_date,
    rm.date_created,
    rm.last_updated,

    SUBSTR(rm.raw_data, 1, 1000) AS raw_data_snip,
    CASE
        WHEN rm.raw_data_long_text IS NOT NULL
        THEN DBMS_LOB.SUBSTR(rm.raw_data_long_text, 3000, 1)
    END AS raw_data_long_text_snip

FROM sample_scope ss
JOIN res_measurementsample rms
    ON rms.mapped_sample_id = ss.sample_pk
    OR rms.sample_id = ss.sample_name
    OR rms.sample_id = ss.sample_id
JOIN res_measurement rm
    ON rm.id = rms.measurement_id
ORDER BY
    ss.target_sample,
    rm.record_date,
    rms.row_index,
    rm.record_name;